#!/bin/sh
# Refuse commits on main. See docs/specs/guardrails.md + session_workflow.md.
# Install once per fresh clone:
#   cp scripts/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
branch="$(git branch --show-current)"
if [ "$branch" = "main" ]; then
  echo "refuse: commit on main — create a session branch first (see docs/specs/session_workflow.md)" >&2
  exit 1
fi
